# Supabase environment — copy to web/.env.local and fill in.
# web/.env.local is gitignored. NEVER commit real keys.
#
# NOTE: this template is named `env.local.example` (no leading dot) on purpose
# so it can be committed; the real file is `.env.local` (gitignored).

# --- Public (safe to expose to the browser) ---
# Only NEXT_PUBLIC_* variables are inlined into client bundles.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Server-only (TRUSTED — never prefix with NEXT_PUBLIC_) ---
# Service-role key bypasses RLS. Read only by web/lib/supabase/service.ts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Upstash Redis (read-side rate limiting, server-only) ---
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
