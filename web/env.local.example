# Supabase environment — copy to web/.env.local and fill in.
# web/.env.local is gitignored. NEVER commit real keys.
#
# NOTE: this template is named `env.local.example` (no leading dot) on purpose
# so it can be committed; the real file is `.env.local` (gitignored).

# --- Public (safe to expose to the browser) ---
# Only NEXT_PUBLIC_* variables are inlined into client bundles.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Server-only (TRUSTED — never prefix with NEXT_PUBLIC_) ---
# Service-role key bypasses RLS. Read only by web/lib/supabase/service.ts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Upstash Redis (read-side rate limiting, server-only) ---
# When unset, the limiter falls back to a process-local in-memory window (still
# enforced — never disabled). Set both to use Upstash in production.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
# Optional: force the in-memory limiter regardless of Upstash (e.g. local dev).
# Tests already force in-memory automatically under Vitest.
# RATELIMIT_BACKEND=memory

# --- Host auth: Google OAuth (task 2.1, server-only) ---
# Read by Supabase (config.toml: [auth.external.google]) — NOT by Next.
# Magic link works without this; Google sign-in needs it set on the project.
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-oauth-client-secret
